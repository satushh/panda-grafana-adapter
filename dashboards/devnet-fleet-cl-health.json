{
  "uid": "devnet-fleet-cl",
  "title": "Devnet Fleet \u2014 CL Health (via panda)",
  "tags": [
    "panda",
    "devnet",
    "consensus"
  ],
  "schemaVersion": 39,
  "version": 0,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "network",
        "type": "query",
        "label": "Network",
        "datasource": {
          "type": "prometheus",
          "uid": "ethpandaops-devnets"
        },
        "query": "label_values(network)",
        "definition": "label_values(network)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "allValue": null,
        "current": {
          "selected": true,
          "text": "glamsterdam-devnet-6",
          "value": "glamsterdam-devnet-6"
        },
        "options": []
      },
      {
        "name": "consensus_client",
        "type": "query",
        "label": "Consensus client",
        "datasource": {
          "type": "prometheus",
          "uid": "ethpandaops-devnets"
        },
        "query": "label_values(consensus_client)",
        "definition": "label_values(consensus_client)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "prysm"
          ],
          "value": [
            "prysm"
          ]
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Network finalized epoch",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "max(beacon_finalized_epoch{network=\"$network\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Network head (max slot)",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "max(beacon_head_slot{network=\"$network\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Target participation",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "100*max(beacon_prev_epoch_target_gwei{network=\"$network\"})/max(beacon_prev_epoch_active_gwei{network=\"$network\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Nodes (selected CLs)",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "count(beacon_head_slot{network=\"$network\",consensus_client=~\"$consensus_client\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Head slot by node",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "beacon_head_slot{network=\"$network\",consensus_client=~\"$consensus_client\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Slots behind network head",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "max(beacon_head_slot{network=\"$network\"}) - beacon_head_slot{network=\"$network\",consensus_client=~\"$consensus_client\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Head slot by client (max)",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
