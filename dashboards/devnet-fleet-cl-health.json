        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "max by(consensus_client)(beacon_head_slot{network=\"$network\"})",
          "legendFormat": "{{consensus_client}}"
        }
      ]
    },
    {
      "id": 8,
