        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "rate(beacon_reorgs_total{network=\"$network\",consensus_client=\"prysm\"}[5m])",
          "legendFormat": "{{instance}}"
