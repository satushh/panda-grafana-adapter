{
  "uid": "devnet-prysm-att-fc",
  "title": "Devnet Prysm \u2014 Attestation & Forkchoice (via panda)",
  "tags": [
    "panda",
    "prysm",
    "devnet"
  ],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "network",
        "type": "query",
        "label": "Network",
        "datasource": {
          "type": "prometheus",
          "uid": "ethpandaops-devnets"
        },
        "query": "label_values(network)",
        "definition": "label_values(network)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "allValue": null,
        "current": {
          "selected": true,
          "text": "glamsterdam-devnet-6",
          "value": "glamsterdam-devnet-6"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Target participation",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "100*max(beacon_prev_epoch_target_gwei{network=\"$network\"})/max(beacon_prev_epoch_active_gwei{network=\"$network\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Head participation",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "100*max(beacon_prev_epoch_head_gwei{network=\"$network\"})/max(beacon_prev_epoch_active_gwei{network=\"$network\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active validators",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "max(beacon_current_active_validators{network=\"$network\",consensus_client=\"prysm\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Reorgs (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "sum(increase(beacon_reorgs_total{network=\"$network\",consensus_client=\"prysm\"}[1h]))",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Participation %",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "100*max(beacon_prev_epoch_target_gwei{network=\"$network\"})/max(beacon_prev_epoch_active_gwei{network=\"$network\"})",
          "legendFormat": "target"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "100*max(beacon_prev_epoch_head_gwei{network=\"$network\"})/max(beacon_prev_epoch_active_gwei{network=\"$network\"})",
          "legendFormat": "head"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "100*max(beacon_prev_epoch_source_gwei{network=\"$network\"})/max(beacon_prev_epoch_active_gwei{network=\"$network\"})",
          "legendFormat": "source"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Avg inclusion delay (slots)",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "ethpandaops-devnets"
          },
          "expr": "rate(attestation_inclusion_delay_slots_sum{network=\"$network\",consensus_client=\"prysm\"}[5m])/rate(attestation_inclusion_delay_slots_count{network=\"$network\",consensus_client=\"prysm\"}[5m])",
          "legendFormat": "{{instance}}"
        }
