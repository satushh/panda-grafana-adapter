    {
      "id": 9,
      "type": "logs",
      "title": "Logs (WARN/ERROR/FATAL)",
      "datasource": {
        "type": "loki",
        "uid": "ethpandaops-devnet-logs"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 10
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "ethpandaops-devnet-logs"
          },
          "expr": "{instance=\"$instance\",container=\"beacon\"} |~ \"(WARN|ERROR|FATAL)\"",
