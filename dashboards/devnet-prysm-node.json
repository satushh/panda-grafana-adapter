      "title": "Attestation inclusion delay (slots)",
      "datasource": {
        "type": "prometheus",
        "uid": "ethpandaops-devnets"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
